# See http://help.github.com/ignore-files/ for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile ~/.gitignore_global

# Ignore bundler config
/.bundle

# Ignore the default SQLite database.
/db/*.sqlite3

# Ignore all logfiles and tempfiles.
/log/*
/tmp

*~

/vendor/plugins/rails_upgrade

# ignore compiled public assets and packs
/public/assets
/public/packs
/data

#ignore .orig and .swp
*.orig
*.swp


#ignore rvm setting file
#.ruby-gemset
#.ruby-version


/.byebug_history
/storage/*


/.hg/
/.idea/


#cssbundling
/app/assets/builds/*
#!/app/assets/builds/.keep

# Node modules
/node_modules
/node_modules/*

/app/assets/builds/*
#!/app/assets/builds/.keep

# vscode workspace
/.vscode

# migrate_2023 runtime artifacts (anomaly log, captured baseline,
# sanity / verify / compare reports, test harness reports)
/script/migrate_2023/migrate_anomalies.log
/script/migrate_2023/sanity_baseline.json
/script/migrate_2023/sanity_report_*
/script/migrate_2023/test_v2_report_*

# Claude Code per-machine settings (permission approvals accumulate local
# paths / hosts here; the shareable counterpart is .claude/settings.json)
/.claude/settings.local.json
