= turbo_frame_tag dom_id(@config,"config"), class: 'w-100' do
  = simple_form_for @config, html: { class: 'config-edit-form' } do |f|
    .config-main
      .config-info
        %span.config-key= @config.key
        .config-description{id: "desc-#{@config.key.gsub('.', '-')}"}
          - if ConfigurationsHelper::DYNAMIC_DESCRIPTIONS[@config.key]
            = dynamic_description_for(@config.key, @config.value)
          - else
            = @config.description
        %span.badge.bg-body-tertiary.text-secondary=@config.value_type.upcase
      .config-value-wrapper.d-flex.align-items-center.gap-2
        - choices = nil
        - if @config.key == 'system.mode'
          - choices = [['Standard', 'standard'], ['Contest', 'contest'], ['Individual Contest', 'indv-contest'], ['Analysis', 'analysis']]
        - elsif @config.key == 'system.group_score_type'
          - choices = [['Group Sum', 'group_sum'], ['Group Max', 'group_max']]
        - elsif @config.key == 'system.scoreboard_view_level'
          - choices = [['Anyone (public)', 'all'], ['Logged-in users', 'user'], ['Admins only', 'admin']]
        
        - if choices
          = f.input :value, collection: choices, include_blank: false, label: false, autofocus: true, input_html: { class: 'form-select form-select-sm', onchange: "updateConfigDescription('#{@config.key}', this.value)" }, wrapper: false
        - else
          = f.input :value, label: false, autofocus: true, input_html: { class: 'form-control-sm' }, wrapper: false
        .btn-group.ms-2
          = button_tag type: 'submit', class: 'btn btn-sm btn-primary' do
            %span.mi.md-18 check
          = link_to grader_configuration_index_path, class: 'btn btn-sm btn-outline-secondary' do
            %span.mi.md-18 close
