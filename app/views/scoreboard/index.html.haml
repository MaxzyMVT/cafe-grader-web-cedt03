.container-fluid.mt-4{"data-controller" => "auto-refresh"}
  .d-flex.justify-content-between.align-items-center.mb-3
    %h1.mb-0
      %i.mi.mi-leaderboard
      Real-time Score Board
    
    .d-flex.align-items-center.gap-3
      = form_with url: scoreboard_path, method: :get, data: { turbo_frame: "scoreboard", turbo_action: "replace" }, class: "d-flex gap-2 align-items-center" do |f|
        .form-check.form-switch
          = f.check_box :mode, { class: 'form-check-input', id: 'modeToggle', onchange: 'this.form.requestSubmit()', checked: @mode == 'group' }, 'group', 'individual'
          %label.form-check-label{for: 'modeToggle'} Group Mode
        
        %select.form-select.form-select-sm{name: "sort", onchange: "this.form.requestSubmit()"}
          %option{value: "rank", selected: params[:sort] != 'name'} Sort by Rank
          %option{value: "name", selected: params[:sort] == 'name'} Sort by Name

  = turbo_frame_tag "scoreboard" do
    .card.shadow-sm
      .card-body.p-0
        .table-responsive{style: "max-height: 80vh; overflow-y: auto;"}
          %table.table.table-hover.table-bordered.m-0.scoreboard-table
            %thead.table-light{style: "position: sticky; top: 0; z-index: 1;"}
              %tr
                %th.text-center{style: "min-width: 60px;"} Rank
                %th{style: "min-width: 200px;"} Name
                %th.text-center{style: "min-width: 100px;"} Total
                - @problems.each do |p|
                  %th.text-center.problem-header{title: p.full_name}
                    .vertical-text= p.name
                    .small.text-muted= p.full_score
            
            %tbody
              - if @mode == 'individual'
                - @leaderboard.each do |entry|
                  %tr
                    %td.text-center.fw-bold= entry[:rank]
                    %td= entry[:user].full_name
                    %td.text-center.fw-bold= entry[:total_score].to_i
                    - @problems.each do |p|
                      - score = @scores[entry[:user].id][p.id] || 0
                      - pct = (p.full_score > 0) ? (score / p.full_score.to_f).clamp(0, 1) : 0
                      %td.text-center.score-cell{style: "background-color: color-mix(in srgb, var(--color-success-bg) #{pct * 100}%, transparent);"}
                        - if score > 0
                          = score.to_i
              - else
                - @leaderboard.each do |entry|
                  %tr.table-secondary
                    %td.text-center.fw-bold= entry[:rank]
                    %td.fw-bold= entry[:group].name
                    %td.text-center.fw-bold= entry[:total_score].to_i
                    %td{colspan: @problems.size}
                  - entry[:members].each do |m|
                    %tr
                      %td.text-center.text-muted.small= m[:rank]
                      %td.ps-4
                        %i.mi.mi-subdirectory-arrow-right.text-muted.me-2
                        = m[:user].full_name
                      %td.text-center= m[:total_score].to_i
                      - @problems.each do |p|
                        - score = @scores[m[:user].id][p.id] || 0
                        - pct = (p.full_score > 0) ? (score / p.full_score.to_f).clamp(0, 1) : 0
                        %td.text-center.score-cell{style: "background-color: color-mix(in srgb, var(--color-success-bg) #{pct * 100}%, transparent);"}
                          - if score > 0
                            = score.to_i

:css
  .scoreboard-table .vertical-text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    white-space: nowrap;
    padding: 10px 0;
    max-height: 150px;
  }
  .scoreboard-table .problem-header {
    vertical-align: bottom;
    min-width: 40px;
    width: 40px;
    padding: 5px;
  }
  .scoreboard-table .score-cell {
    transition: background-color 0.3s ease;
    font-size: 0.9em;
  }
