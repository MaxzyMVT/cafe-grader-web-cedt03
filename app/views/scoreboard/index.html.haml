- content_for :head do
  %meta{name: "turbo-cache-control", content: "no-cache"}
  %meta{name: "turbo-refresh-method", content: "morph"}
  %meta{name: "turbo-refresh-scroll", content: "preserve"}

.container-fluid.mt-4{"data-controller" => "auto-refresh", id: "scoreboard-container"}
  .d-flex.justify-content-between.align-items-center.mb-3
    %h1.mb-0
      %i.mi.mi-leaderboard
      Real-time Score Board
    
    .d-flex.align-items-center.gap-3
      = form_with url: scoreboard_path, method: :get, data: { turbo_frame: "scoreboard", turbo_action: "replace" }, class: "d-flex gap-3 align-items-center mb-0" do |f|
        .form-check.form-switch.d-flex.align-items-center.gap-2.mb-0.ps-0
          = f.check_box :mode, { class: 'form-check-input m-0', style: 'margin-left: 0;', id: 'modeToggle', onchange: 'this.form.requestSubmit()', checked: @mode == 'group' }, 'group', 'individual'
          %label.form-check-label.text-nowrap.mb-0{for: 'modeToggle'} Group Mode
        
        %select.form-select.form-select-sm{name: "sort", onchange: "this.form.requestSubmit()", style: "width: auto;"}
          %option{value: "rank", selected: params[:sort] != 'name'} Sort by Rank
          %option{value: "name", selected: params[:sort] == 'name'} Sort by Name

  = turbo_frame_tag "scoreboard" do
    - if @mode == 'group'
      .d-flex.justify-content-center.mb-3
        .d-flex.w-100{style: "min-width: 75%; max-width: 100%;"}
          %span.badge.bg-info-subtle.text-info-emphasis.border.border-info-subtle.px-3.py-2.fs-6.d-inline-flex.align-items-center.gap-2
            %i.mi.mi-info.md-18
            %span
              Scoring Mode:
              %strong= @group_score_type == 'group_max' ? "Group Max (Highest score per problem)" : "Group Sum (Sum of member scores)"
    .d-flex.justify-content-center
      .card.shadow-sm.scoreboard-card{style: "min-width: 75%; max-width: 100%;"}
        .card-body.p-0
          .table-responsive{style: "max-height: 80vh; overflow-y: auto;"}
            %table.table.table-hover.table-bordered.m-0.scoreboard-table.w-100
              %thead.table-light
                %tr
                  %th.text-center{style: "min-width: 60px;"} Rank
                  %th{style: "min-width: 200px;"} Name
                  %th.text-center{style: "min-width: 80px;"} Sum
                  - if GraderConfiguration.enable_bonus?
                    %th.text-center{style: "min-width: 80px;"} Bonus
                  - if GraderConfiguration.enable_penalty?
                    %th.text-center{style: "min-width: 80px;"} Deducted
                  - @problems.each do |p|
                    %th.text-center.problem-header{title: p.full_name}
                      .vertical-text.mx-auto= p.name
                      .small.text-muted= p.effective_full_score || 100
                      - if GraderConfiguration.show_first_bloods? && p.bonus_first_blood.to_f != 0
                        - n = p.respond_to?(:first_n_bloods) ? p.first_n_bloods : 0
                        - if n > 0
                          .badge.bg-danger-subtle.text-danger.p-1.mt-1{title: "First #{n} Bloods Bonus: #{p.bonus_first_blood}"}
                            %span.mi.md-12 bloodtype
                            - formatted_bonus = p.bonus_first_blood.to_f > 0 ? "+#{format_score(p.bonus_first_blood)}" : format_score(p.bonus_first_blood)
                            %span.fw-bold.small= "#{formatted_bonus} (x#{n})"
              
              %tbody
                - if @mode == 'individual'
                  - @leaderboard.each do |entry|
                    %tr
                      %td.text-center.fw-bold= entry[:rank]
                      %td
                        = entry[:user].full_name
                        - if @current_user && entry[:user].id == @current_user.id
                          %br
                          %small.text-muted (You)
                      %td.text-center.fw-bold= format_score(entry[:total_score])
                      - if GraderConfiguration.enable_bonus?
                        %td.text-center.text-success= format_score(entry[:bonus_score]) if entry[:bonus_score].to_f > 0
                      - if GraderConfiguration.enable_penalty?
                        %td.text-center.text-danger= format_score(entry[:deducted_score]) if entry[:deducted_score].to_f > 0
                      - @problems.each do |p|
                        - if user_associated_with_problem?(entry[:user].id, p.id)
                          - score = @scores[entry[:user].id][p.id] || 0
                          - full_score = p.effective_full_score || 100
                          - is_zero_pass = (full_score == 0 && @zero_score_passes[entry[:user].id] && @zero_score_passes[entry[:user].id][p.id])
                          - pct = is_zero_pass ? 1.0 : ((full_score.to_f.abs > 0) ? (score.to_f.abs / full_score.to_f.abs).clamp(0, 1) : 0)
                          %td.text-center.score-cell{style: "background-color: color-mix(in srgb, var(--color-success-bg) #{pct * 100}%, transparent);"}
                            - if @scores[entry[:user].id].has_key?(p.id)
                              %div.d-flex.align-items-center.justify-content-center.gap-1
                                = format_score(score)
                                - if GraderConfiguration.show_first_bloods? && p.bonus_first_blood.to_f != 0 && @first_blood_users[p.id] && (idx = @first_blood_users[p.id].index(entry[:user].id))
                                  - formatted_bonus = p.bonus_first_blood.to_f > 0 ? "+#{format_score(p.bonus_first_blood)}" : format_score(p.bonus_first_blood)
                                  %span.mi.text-danger.md-12{title: "Blood Winner ##{idx + 1}! Received #{formatted_bonus} bonus!"} bloodtype
                        - else
                          %td.text-center.score-cell.text-muted
                            %span{style: "opacity: 0.4;"} —
                - else
                  - @leaderboard.each do |entry|
                    %tr.table-secondary
                      %td.text-center.fw-bold= entry[:rank]
                      %td.fw-bold= entry[:group].name
                      %td.text-center.fw-bold= format_score(entry[:total_score])
                      - if GraderConfiguration.enable_bonus?
                        %td.text-center.text-success.fw-bold= format_score(entry[:bonus_score]) if entry[:bonus_score].to_f > 0
                      - if GraderConfiguration.enable_penalty?
                        %td.text-center.text-danger= format_score(entry[:deducted_score]) if entry[:deducted_score].to_f > 0
                      - @problems.each do |p|
                        - if group_associated_with_problem?(entry[:group].id, p.id)
                          - group_score = @group_score_type == 'group_max' ? entry[:members].map { |m| @scores[m[:user].id][p.id] || 0 }.max : entry[:members].map { |m| @scores[m[:user].id][p.id] || 0 }.sum
                          %td.text-center.fw-bold
                            = format_score(group_score) if group_score.to_f > 0
                        - else
                          %td.text-center.score-cell.text-muted
                            %span{style: "opacity: 0.4;"} —
                    - entry[:members].each do |m|
                      %tr
                        %td.text-center.text-muted.small= m[:rank]
                        %td.ps-4
                          .d-flex.align-items-start
                            %i.mi.mi-subdirectory-arrow-right.text-muted.me-2.mt-1
                            %div
                              = m[:user].full_name
                              - if @current_user && m[:user].id == @current_user.id
                                %br
                                %small.text-muted (You)
                        %td.text-center= format_score(m[:total_score])
                        - if GraderConfiguration.enable_bonus?
                          %td.text-center.text-success= format_score(m[:bonus_score]) if m[:bonus_score].to_f > 0
                        - if GraderConfiguration.enable_penalty?
                          %td.text-center.text-danger= format_score(m[:deducted_score]) if m[:deducted_score].to_f > 0
                        - @problems.each do |p|
                          - if user_associated_with_problem?(m[:user].id, p.id)
                            - score = @scores[m[:user].id][p.id] || 0
                            - full_score = p.effective_full_score || 100
                            - is_zero_pass = (full_score == 0 && @zero_score_passes[m[:user].id] && @zero_score_passes[m[:user].id][p.id])
                            - pct = is_zero_pass ? 1.0 : ((full_score.to_f.abs > 0) ? (score.to_f.abs / full_score.to_f.abs).clamp(0, 1) : 0)
                            %td.text-center.score-cell{style: "background-color: color-mix(in srgb, var(--color-success-bg) #{pct * 100}%, transparent);"}
                              - if @scores[m[:user].id].has_key?(p.id)
                                %div.d-flex.align-items-center.justify-content-center.gap-1
                                  = format_score(score)
                                  - if GraderConfiguration.show_first_bloods? && p.bonus_first_blood.to_f != 0 && @first_blood_users[p.id] && (idx = @first_blood_users[p.id].index(m[:user].id))
                                    - formatted_bonus = p.bonus_first_blood.to_f > 0 ? "+#{format_score(p.bonus_first_blood)}" : format_score(p.bonus_first_blood)
                                    %span.mi.text-danger.md-12{title: "Blood Winner ##{idx + 1}! Received #{formatted_bonus} bonus!"} bloodtype
                          - else
                            %td.text-center.score-cell.text-muted
                              %span{style: "opacity: 0.4;"} —

:css
  .scoreboard-card, .scoreboard-card:hover {
    mask-image: none !important;
    -webkit-mask-image: none !important;
    isolation: auto !important;
    transform: none !important;
    box-shadow: none !important;
  }
  .scoreboard-table, .scoreboard-table tr, .scoreboard-table td, .scoreboard-table th {
    transition: none !important;
  }
  .scoreboard-table .vertical-text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    white-space: nowrap;
    padding: 10px 0;
    max-height: 150px;
    margin: 0 auto;
    text-align: center;
  }
  .scoreboard-table .problem-header {
    vertical-align: bottom;
    min-width: 40px;
    width: 40px;
    padding: 5px;
  }
  .scoreboard-table .score-cell {
    font-size: 0.9em;
  }
