.d-flex.flex-column.flex-sm-row.justify-content-between.align-items-start.align-items-sm-center.gap-3.mb-4
  %h2.fw-bold.mb-0 Console: Active Messages
  .d-flex.flex-wrap.gap-2
    = link_to list_all_messages_path, class: 'btn btn-outline-secondary d-flex align-items-center gap-2 shadow-sm' do
      %span.mi.md-18 list
      All Messages
    = button_to clear_all_messages_path, 
        method: :post, 
        data: { confirm: 'Are you sure you want to clear ALL system messages? This cannot be undone.' },
        class: 'btn btn-danger d-flex align-items-center gap-2 shadow-sm' do
      %span.mi.md-18 delete_sweep
      Clear All Messages

.card.card-shadow.border-0
  .card-body.p-0
    .table-responsive
      %table.table.table-hover.align-middle.mb-0
        %thead.bg-surface-alt
          %tr
            %th.ps-4 From
            %th When
            %th Message
            %th.text-end.pe-4 Actions
        %tbody
          = render partial: "short_message", collection: @messages
