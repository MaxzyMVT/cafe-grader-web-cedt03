.row
  .col-lg-8
    .card.card-shadow.border-0.bg-surface-alt.mb-4
      .card-body.p-4
        %h5.fw-bold.mb-4.d-flex.align-items-center.gap-2
          %span.mi.text-primary help_outline
          How to submit clarification requests
        .text-muted.mb-0
          %p.mb-2 Clarification requests should be phrased as yes/no questions.
          %p.mb-1 The answers will be one of the following:
          .row.g-2.mt-1
            - ["YES", "NO", "ANSWERED IN TASK DESCRIPTION", "INVALID QUESTION", "NO COMMENT"].each do |ans|
              .col-auto
                %span.badge.bg-light.text-secondary.border.px-3= ans

    - if GraderConfiguration.message_enabled? || @current_user.admin?
      .card.card-shadow.border-0.mb-4
        .card-body.p-4
          %h5.fw-bold.mb-4.d-flex.align-items-center.gap-2
            %span.mi.text-primary add_comment
            New Clarification Request
          
          = form_for 'message', url: { action: 'create' } do |f|
            .mb-3
              = f.text_area :body, rows: 4, class: 'form-control', placeholder: 'Type your question here...'
            .d-flex.justify-content-end
              = f.submit "Post Request", class: 'btn btn-primary px-4 shadow-sm'
    - else
      .card.border-0.bg-danger-subtle.text-danger.mb-4.shadow-sm
        .card-body.p-4.d-flex.align-items-center.gap-3
          %span.mi.md-36 block
          %div
            %h6.fw-bold.mb-1 Clarification requests are disabled
            %p.small.mb-0 The staff has disabled new clarification requests for this session.

    .messages-feed
      = render partial: 'message', collection: @messages, locals: { reply: false }

  .col-lg-4
    -# Optional sidebar info
    .card.border-0.bg-primary-subtle.text-primary.p-4.rounded-4
      %h6.fw-bold.mb-2.d-flex.align-items-center.gap-2
        %span.mi info
        Note
      %p.small.mb-0
        Staff will review your requests and provide answers as soon as possible. Check this page periodically for updates.
