%div
  %h3.mb-1
    - if local_assigns[:prefix]
      %span= prefix
    %span.font-monospace.text-secondary [#{problem.name}]
    %span #{problem.full_name}
    - if local_assigns[:suffix]
      %span= suffix

  .d-flex.gap-2.mb-3
    .badge.bg-info.text-dark.d-inline-flex.align-items-center.justify-content-center{style: 'min-width: 140px; height: 24px;'}
      Full Score: #{number_with_precision(problem.full_score, precision: 2, strip_insignificant_zeros: true)}
    - if problem.bonus_first_blood.to_f != 0
      - n = problem.respond_to?(:first_n_bloods) ? problem.first_n_bloods : 0
      - if n > 0
        .badge.bg-danger-subtle.text-danger.d-inline-flex.align-items-center.justify-content-center{title: "First #{n} Bloods Bonus", style: 'min-width: 180px; height: 24px;'}
          %span.mi.md-14.me-1 bloodtype
          - formatted_bonus = problem.bonus_first_blood.to_f > 0 ? "+#{format_score(problem.bonus_first_blood)}" : format_score(problem.bonus_first_blood)
          Bonus: #{formatted_bonus} (First #{n})
