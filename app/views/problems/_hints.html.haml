- hints = problem.comments_with_reveal_status(@current_user,kind: [:hint])
- if hints.any?
  - hints.each do |hint|
    .row.mb-2.align-items-center
      .col
        .badge.rounded-pill.text-success.bg-success-subtle.me-2 Hint
        #{hint.title}
      .col-auto.text-end.d-flex.justify-content-end.align-items-center.gap-2.flex-nowrap
        -# view the hint
        - is_available = @current_user.admin? || @current_user.problem_setter? || hint.available_in_contest?(@current_contest, @current_contest_user)
        - if !is_available
          - remaining_seconds = 0
          - if @current_contest
            - user_start_time = @current_contest.start - (@current_contest_user&.start_offset_second || 0).seconds
            - release_time = user_start_time + hint.available_after.seconds
            - remaining_seconds = (release_time - Time.zone.now).to_i
          %span.badge.bg-warning-subtle.text-warning.d-inline-flex.align-items-center.gap-1{title: "Hint unlocks after #{hint.available_after} seconds from contest start."}
            %span.mi{style: 'font-size: 0.85rem;'} lock
            - if remaining_seconds > 0
              Locked (#{remaining_seconds}s)
            - else
              Locked
          %button.btn.btn-sm.btn-secondary{disabled: true, style: 'min-width: 60px;'} Get
        - elsif hint.is_acquired?
          = link_to 'View', problem_hint_path(problem,hint), data: {turbo_stream: true}, class: 'btn btn-sm btn-outline-success', style: 'min-width: 60px;'
        - else
          - fs_cost = number_with_precision(hint.cost || 0, precision: 2, strip_insignificant_zeros: true)
          - p_cost = hint.all_points ? "All" : number_with_precision(hint.point_cost || 0, precision: 2, strip_insignificant_zeros: true)
          - rate = hint.success_rate || 100.0
          - can_buy = hint.acquirable_by?(@current_user, @current_contest, @current_contest_user)
          
          %span.text-muted.small.d-flex.align-items-center.gap-1{title: "Points: #{p_cost}, Cap: #{fs_cost}#{rate < 100.0 ? ", Rate: #{rate}%" : ""}"}
            %span{title: 'Points Cost'} 💰#{p_cost}
            %span{title: 'Score Cap'} 📉#{fs_cost}
            - if rate < 100.0
              %span{title: 'Success Rate'} 🎲#{number_with_precision(rate, precision: 2, strip_insignificant_zeros: true)}%
          
          - if !can_buy
            %button.btn.btn-sm.btn-secondary{disabled: true, style: 'min-width: 60px;'} Get
          - else
            - body_text = render partial: 'problems/acquire_hint_confirm', locals: {hint: hint}
            - confirmation = {title: "Confirm getting a hint", body: body_text}
            = link_to 'Get', acquire_problem_hint_path(problem,hint), data: {turbo_stream: true, turbo_method: 'POST', turbo_confirm: confirmation.to_json}, class: 'btn btn-sm btn-outline-primary', style: 'min-width: 60px;'
- else
  .row
    .col
      %em.text-muted.small -- There is no hint for this problem --
