-# problem name
%div.d-inline-block.w-100
  %strong.me-1
    = "#{problem.full_name}".gsub("_","_&ZeroWidthSpace;").html_safe
  %span.d-inline-flex.align-items-center.flex-wrap{style: 'color: var(--bs-orange); max-width: 100%;'}= render_star(problem.difficulty)
.text-muted.font-monospace
  = "#{problem.name}".gsub("_","_&ZeroWidthSpace;").html_safe
- if problem.submission_limit? && @current_user
  - limit_reached = problem.submission_limit_reached?(@current_user)
  - sub_count = problem.submission_count_for(@current_user)
  - remaining = problem.submissions_remaining_for(@current_user)
  %span.badge.rounded-pill.d-inline-flex.align-items-center.gap-1.ms-1{class: (limit_reached ? 'badge-limit-danger' : 'badge-limit-info'), 'data-bs-toggle' => 'tooltip', title: (limit_reached ? 'Submission limit reached' : "#{remaining} submission#{'s' unless remaining == 1} remaining")}
    %span.mi{style: 'font-size: 0.85rem;'} upload
    = "#{sub_count}/#{problem.max_submissions} subs"
- if problem.bonus_first_blood.to_f != 0
  - n = problem.respond_to?(:first_n_bloods) ? problem.first_n_bloods : 0
  - if n > 0
    %span.badge.rounded-pill.bg-danger-subtle.text-danger.d-inline-flex.align-items-center.gap-1.ms-1{title: "First #{n} Bloods Bonus"}
      %span.mi{style: 'font-size: 0.85rem;'} bloodtype
      - formatted_bonus = problem.bonus_first_blood.to_i > 0 ? "+#{problem.bonus_first_blood.to_i}" : problem.bonus_first_blood.to_i.to_s
      = "#{formatted_bonus} (x#{n})"

-# link for download statement, attachment, testcases
%div.d-inline-flex.align-items-center.align-middle.gap-1
  = link_to_description_if_any "<span class='mi md-18'>description</span> Read".html_safe, problem, class: 'link-flex'
  - if problem.attachment.attached?
    .d-md-none
    %span.d-none.d-md-inline
      |
    = link_to "<span class='mi md-18'>archive</span> File".html_safe, download_by_type_problem_path(problem,'attachment'), class: 'link-flex'
  - if problem.can_view_testcase
    %span
      |
    = link_to "<span class='mi md-18'>bug_report</span> Testcases".html_safe, show_problem_testcases_path(problem), class: 'link-flex'
-# public tags
%div
  - problem.public_tags.each do |tag|
    - data_hash = tag.description.present? ? {bs: {toggle: 'tooltip', title: tag.description }} : nil
    - if tag.color.blank?
      %span.badge.text-bg-secondary{data: data_hash}= tag.name
    - else
      %span.badge{style: "background-color: #{tag.color}", data: data_hash}= tag.name
