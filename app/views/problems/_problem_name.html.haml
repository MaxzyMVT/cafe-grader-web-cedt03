-# problem name
%div.d-inline-block.w-100
  %strong.me-1
    = "#{problem.full_name}".gsub("_","_&ZeroWidthSpace;").html_safe
  %span.d-inline-flex.align-items-center.flex-wrap{style: 'color: var(--bs-orange); max-width: 100%;'}= render_star(problem.difficulty)
.text-muted.font-monospace
  = "#{problem.name}".gsub("_","_&ZeroWidthSpace;").html_safe
- if GraderConfiguration.show_submission_limits? && problem.submission_limit? && @current_user
  - is_exempt = @current_user.admin? || @current_user.problem_setter?
  - limit_reached = !is_exempt && problem.submission_limit_reached?(@current_user)
  - sub_count = problem.submission_count_for(@current_user)
  - remaining = is_exempt ? nil : problem.submissions_remaining_for(@current_user)
  - if is_exempt
    %span.badge.rounded-pill.d-inline-flex.align-items-center.gap-1.ms-1.bg-success-subtle.text-success.border.border-success-subtle{'data-bs-toggle' => 'tooltip', title: 'Exempt from limit (You can submit indefinitely)'}
      %span.mi{style: 'font-size: 0.85rem;'} upload
      = "#{sub_count}/#{problem.max_submissions} subs"
  - else
    %span.badge.rounded-pill.d-inline-flex.align-items-center.gap-1.ms-1{class: (limit_reached ? 'badge-limit-danger' : 'badge-limit-info'), 'data-bs-toggle' => 'tooltip', title: (limit_reached ? 'Submission limit reached' : "#{remaining} submission#{'s' unless remaining == 1} remaining")}
      %span.mi{style: 'font-size: 0.85rem;'} upload
      = "#{sub_count}/#{problem.max_submissions} subs"
- if GraderConfiguration.show_first_bloods? && problem.bonus_first_blood.to_f != 0
  - n = problem.respond_to?(:first_n_bloods) ? problem.first_n_bloods : 0
  - if n > 0
    - blood_users = problem.first_n_blood_users(n)
    - user_got_it = @current_user && blood_users.include?(@current_user)
    - left = n - blood_users.size
    - if user_got_it
      - pct = 0
      - outline_color = 'transparent'
      - badge_class = 'bg-success-subtle text-success border border-success-subtle'
    - elsif left > 0
      - pct = (left.to_f / n.to_f * 100).round
      - outline_color = 'var(--bs-danger)'
      - badge_class = 'bg-danger-subtle text-danger border border-danger-subtle'
    - else
      - pct = 0
      - outline_color = 'transparent'
      - badge_class = 'bg-secondary-subtle text-secondary border border-secondary-subtle'
    - formatted_bonus = problem.bonus_first_blood.to_f > 0 ? "+#{format_score(problem.bonus_first_blood)}" : format_score(problem.bonus_first_blood)
    - text = user_got_it ? "#{formatted_bonus} ✓" : ((left == n) ? "#{formatted_bonus} (x#{n})" : "#{formatted_bonus} (#{left}/#{n})")
    %span.badge.rounded-pill.d-inline-flex.align-items-center.gap-1.ms-1.progress-outline-badge{class: badge_class, style: "--progress-pct: #{pct}%; --progress-color: #{outline_color};", title: user_got_it ? "First Blood achieved! Bonus: #{formatted_bonus}" : "First #{n} Bloods Bonus"}
      %span.mi{style: 'font-size: 0.85rem;'} bloodtype
      = text

-# link for download statement, attachment, testcases
%div.d-inline-flex.align-items-center.align-middle.gap-1
  = link_to_description_if_any "<span class='mi md-18'>description</span> Read".html_safe, problem, class: 'link-flex'
  - if problem.statement.attached?
    = link_to download_by_type_problem_path(problem, 'statement', disposition: 'attachment'), class: 'text-secondary d-inline-flex align-items-center p-0', title: 'Download statement' do
      %span.mi{style: 'font-size: 1.1rem;'} download
  - if problem.attachment.attached?
    .d-md-none
    %span.d-none.d-md-inline
      |
    = link_to "<span class='mi md-18'>archive</span> File".html_safe, download_by_type_problem_path(problem,'attachment'), class: 'link-flex'
    = link_to download_by_type_problem_path(problem, 'attachment', disposition: 'attachment'), class: 'text-secondary d-inline-flex align-items-center p-0', title: 'Download file' do
      %span.mi{style: 'font-size: 1.1rem;'} download
  - if problem.can_view_testcase
    %span
      |
    = link_to "<span class='mi md-18'>bug_report</span> Testcases".html_safe, show_problem_testcases_path(problem), class: 'link-flex'
-# public tags
%div
  - problem.public_tags.each do |tag|
    - data_hash = tag.description.present? ? {bs: {toggle: 'tooltip', title: tag.description }} : nil
    - if tag.color.blank?
      %span.badge.text-bg-secondary{data: data_hash}= tag.name
    - else
      %span.badge{style: "background-color: #{tag.color}; color: #{contrast_text_color(tag.color)};", data: data_hash}= tag.name
