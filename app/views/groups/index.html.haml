.row.my-2{data: {controller: 'group'}}
  .col-md-5.mb-3
    .d-flex.flex-column.gap-1.mb-3
      %small.text-secondary.text-uppercase.fw-bold.ls-1 Access Control
      %h2.fw-bold.text-dark.mb-0 Groups
    
    .d-flex.flex-wrap.gap-2
      = link_to mdi(:add, 'me-1') + 'New Group', new_group_path, class: 'btn btn-flex btn-success'
      = link_to mdi('checklist', 'me-1') + 'Bulk Manage', bulk_manage_groups_path, class: 'btn btn-flex btn-outline-secondary'
  .col-md-7.mb-3
    = render partial: 'group_help'

.card.shadow-sm
  .card-body
    %table#group-table.table.table-hover
      %thead
        %tr
          %th Name
          %th Description
          %th Enabled?
          %th Members can rename group
          %th
      %tbody
        - @groups.each do |group|
          %tr{:class => "#{(group.enabled?) ? "success" : "danger"}", id: "group-#{group.id}"}
            %td= group.name
            %td= group.description
            %td
              .form-check.form-switch
                %input.form-check-input{id: "group-#{group.id}-enabled-switch", checked: group.enabled, type: "checkbox", data: {action: 'group#toggle', 'row-id': group.id}}
            %td
              .form-check.form-switch
                %input.form-check-input{id: "group-#{group.id}-member-rename-switch", checked: group.allow_user_change_name, type: "checkbox", data: {action: 'group#toggleMemberRename', 'row-id': group.id}}
            %td.text-end.align-middle.py-0
              .d-inline-flex.align-items-center.gap-3
                = link_to mdi('settings','md-24') + ' Manage', group, class: 'btn btn-flex btn-outline-primary border-0'
                = link_to mdi('delete', 'md-24'), group, :method => :delete, :data => { :confirm => 'Are you sure?' }, class: 'btn btn-flex btn-outline-danger border-0'

-# hidden form for group toggle
= form_with url: toggle_group_path(-123), html: {data: {turbo: true, 'group-target': 'toggleForm', action: 'turbo:submit-end->group#resetToggleForm'}} do
  /

= form_with url: toggle_member_rename_group_path(-123), html: {data: {turbo: true, 'group-target': 'toggleMemberRenameForm', action: 'turbo:submit-end->group#resetToggleForm'}} do
  /

:javascript
  window.addEventListener("load", function() {
    //on doc ready
    table_config = {
      paging: false,
      layout: {
        topStart: 'info',
        topEnd: 'search',
      },
      columnDefs: [{orderable: false, targets: [2,3,4]} ],
    }

    table = $('#group-table').DataTable(table_config)

  })

  function set_group_switch(group_id, enabled) {
    document.getElementById(`group-${group_id}-enabled-switch`).checked = enabled
    document.getElementById(`group-${group_id}-enabled-switch`).disabled = false
  }
