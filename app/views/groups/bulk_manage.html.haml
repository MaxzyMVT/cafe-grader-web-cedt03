= render 'application/breadcrumb', steps: [{ label: 'Groups', path: groups_path, icon: resource_icon_name(Group) }, { label: 'Manage' }]
.d-flex.justify-content-between.align-items-center.mb-4
  .d-flex.flex-column.gap-1
    %small.text-secondary.text-uppercase.fw-bold.ls-1 Management
    %h2.fw-bold.text-dark.mb-0 Bulk Manage Groups

- if @result && @result.count > 0
  .alert.alert-info
    %ul.mb-0
      - @result.each do |r|
        %li= r
- if @error && @error.count > 0
  .alert.alert-danger
    %ul.mb-0
      - @error.each do |r|
        %li= r

= form_with url: bulk_manage_groups_path, class: 'align-items-center',
  data: {turbo: true, action: 'turbo:submit-end->group#bulkManageSubmitEnd', controller: 'init-ui-component' } do |f|
  .card.card-shadow.mb-4
    .card-body
      .d-flex.align-items-start.mb-3
        .bg-primary-subtle.text-primary.rounded-3.d-flex.align-items-center.justify-content-center.me-3{ style: "width: 48px; height: 48px; flex-shrink: 0;" }
          %span.mi.md-36.fill build
        .flex-grow-1
          %h5.fw-bold.text-dark.mb-0 Bulk Actions
          %small.text-muted Select groups below, choose actions, then apply. You can shift-click to select a range.
      .row
        .col-md-6
          .row.mb-3.align-items-center
            .col-md-auto
              .form-check
                = f.check_box :change_enable, class: 'form-check-input manage-action'
                = f.label :change_enable, 'Set "Enabled" to'
            .col-md-auto
              = f.radio_button :enable, "yes", class: 'form-check-input manage-action'
              = f.label :enable_yes, "yes"
            .col-md-auto
              = f.radio_button :enable, "no", class: 'form-check-input manage-action'
              = f.label :enable_no, "no"
        .col-md-6
          .row.mb-3.align-items-center
            .col-md-auto
              .form-check
                = f.check_box :change_allow_user_change_name, class: 'form-check-input manage-action'
                = f.label :change_allow_user_change_name, 'Set "Allow member change name" to'
            .col-md-auto
              = f.radio_button :allow_user_change_name, "yes", class: 'form-check-input manage-action'
              = f.label :allow_user_change_name_yes, "yes"
            .col-md-auto
              = f.radio_button :allow_user_change_name, "no", class: 'form-check-input manage-action'
              = f.label :allow_user_change_name_no, "no"
      .d-flex.justify-content-end.border-top.pt-3
        = f.submit 'Apply to Selected', class: 'btn btn-primary btn-flex px-4'

  .card.card-shadow
    .card-body
      .table-responsive
        %table#main-table.table.table-hover.table-condense.align-middle.datatable
          %thead
            %tr
              %th.text-center
                .form-check.d-inline-block
                  %input#select_all.form-check-input.form-check-thick{type: :checkbox}
              %th Name
              %th Description
              %th Users
              %th Problems
              %th Enabled
              %th Allow user name change

:javascript
  window.addEventListener("load", function() {

    function check_box_render(data,type,row,meta) {
      if (type == 'display') {
        return `<div class="form-check d-inline-block"><input class="form-check-input form-check-thick group-select-check" type="checkbox" id="group-${data}" name="group-${data}"> </div>`
      }
      return data;
    }

    table = $('.datatable').DataTable({
      paging: false,
      ajax: {
        url: '#{bulk_manage_query_groups_path}',
        type: 'POST',
        dataType: 'json',
        beforeSend: (request) => {
          request.setRequestHeader('X-CSRF-Token', $('meta[name="csrf-token"]').attr('content'));
        },
      },
      columns: [
        {data: 'id', name: 'checkbox', render: check_box_render, className: 'text-center'},
        {data: 'name'},
        {data: 'description'},
        {data: 'users_count', className: 'text-end'},
        {data: 'problems_count', className: 'text-end'},
        {data: 'enabled', render: cafe.dt.render.yes_no_pill()},
        {data: 'allow_user_change_name', render: cafe.dt.render.yes_no_pill()},
      ],
      columnDefs: [{orderable: false, targets: [0]} ],
      order: [[1, 'asc']],
    });

    let firstRowIndex = null;
    const checkboxColumnIndex = table.column('checkbox:name').index();

    $('#main-table tbody').on('click', 'td', function(e) {
      let cell = table.cell(this).index()
      if (cell.column != checkboxColumnIndex) return
      if (e.shiftKey && firstRowIndex !== null) {
          const lastRowIndex = table.cell(this).index().row;

          let start = table.rows().count() + 1
          let end = -1
          table.rows().every( function(rowIdx, tableLoop, rowLoop) {
            if (rowIdx == firstRowIndex || rowIdx == lastRowIndex) {
              start = Math.min(start,rowLoop)
              end = Math.max(end,rowLoop)
            }
          })

          const target_checked = document.getElementById(`group-${table.row(lastRowIndex).data().id}`).checked
          table.rows().every( function(rowIdx, tableLoop, rowLoop) {
            if (rowLoop >= start && rowLoop <= end) {
              document.getElementById(`group-${table.row(rowIdx).data().id}`).checked = target_checked
            }
          })
      } else {
          firstRowIndex = table.cell(this).index().row;
      }
    });

    $('#select_all').on('click', function(e) {
      $('.group-select-check').prop('checked',e.target.checked)
    })
  });
