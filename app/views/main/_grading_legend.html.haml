.card.card-shadow.border-0.bg-surface-alt.mt-4
  .card-body.p-4
    %h6.fw-bold.text-uppercase.text-secondary.mb-4.d-flex.align-items-center.gap-2
      %span.mi info
      = t 'help.grading_legend.title'
    
    .space-y-3
      - [ { symbol: 'P', color: 'success', text: t('help.grading_legend.p') },
          { symbol: '-', color: 'danger', text: t('help.grading_legend.wrong') },
          { symbol: 'S', color: 'secondary', text: t('help.grading_legend.s') },
          { symbol: 'T', color: 'warning', text: t('help.grading_legend.t'), text_dark: true },
          { symbol: 'M', color: 'warning', text: t('help.grading_legend.m'), text_dark: true },
          { symbol: 'X', color: 'danger', text: t('help.grading_legend.x') },
          { symbol: '!', color: 'danger', text: t('help.grading_legend.grader_error') } ].each do |item|
         .d-flex.align-items-start.gap-3.py-2
          %span.badge.rounded-pill.px-3{class: "bg-#{item[:color]} #{'text-dark' if item[:text_dark]}", style: 'width: 2.8rem; height: 1.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;'}
            = item[:symbol]
          %div
            - text = item[:text]
            - if text.include?('(')
              - main_text, subtext = text.split('(', 2)
              %span.fw-semibold.text-dark{style: 'line-height: 1.4;'}= main_text.strip
              %span.d-block.text-muted.small.fw-normal.mt-1= "(#{subtext.strip}"
            - else
              %span.fw-semibold.text-dark{style: 'line-height: 1.4;'}= text
    
    .mt-4.pt-3.border-top
      %p.text-muted.small.mb-0.d-flex.align-items-center.gap-2
        %span.mi.md-18 groups
        = t 'help.grading_legend.group_info'
