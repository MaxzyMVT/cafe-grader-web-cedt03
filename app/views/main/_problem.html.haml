%tr
  %td.text-end.d-none.d-sm-table-cell{'data-order': @numbering}
    %div= @numbering
    - if @current_user&.admin?
      .mt-1
        = link_to stat_problem_path(problem), class: 'text-secondary text-decoration-none', 'data-bs-toggle' => 'tooltip', title: 'View Statistics' do
          %span.mi{style: 'font-size: 1.2rem; vertical-align: middle;'} bar_chart
        = link_to edit_problem_path(problem), class: 'text-secondary text-decoration-none', 'data-bs-toggle' => 'tooltip', title: 'Edit Problem' do
          %span.mi{style: 'font-size: 1.2rem; vertical-align: middle;'} edit
  - @numbering+=1
  -# problem name, pdf, attachments, etc.
  - limit_reached = problem.submission_limit_reached?(@current_user)
  %td{style: 'min-width: 150px; max-width: 450px; overflow-wrap: anywhere;'}
    = render partial: 'problems/problem_name', locals: {problem: problem}
    .d-md-none.mt-1
      %span.badge.bg-light.text-dark.border
        Full: #{number_with_precision problem.full_score, precision: 2, strip_insignificant_zeros: true}

  %td.text-end.d-none.d-md-table-cell{style: 'width: 5rem;'}
    = number_with_precision problem.full_score, precision: 2, strip_insignificant_zeros: true

  -# score column
  - score = @prob_submissions[problem.id][:max_score] || 0
  - full_score = problem.full_score || 100
  - raw_sum_mode = problem.live_dataset&.st_raw_sum?
  - cc = score >= full_score ? 'bg-success' : 'bg-warning text-dark'
  %td{style: "width: 10rem; min-width: 8rem; vertical-align: middle", 'data-order': score || 0}
    - if raw_sum_mode
      %span.fw-semibold
        = number_with_precision score, precision: 2, strip_insignificant_zeros: true
    - else
      - text = []
      - hint_cost = @prob_submissions[problem.id][:hint_cost] || 0
      - ai_cost = @prob_submissions[problem.id][:ai_assist_cost] || 0
      - sum_cost = [full_score, hint_cost + ai_cost].min
      - ai_count = @prob_submissions[problem.id][:ai_assist_count]
      - text << "AI: #{ai_count}" if ai_count
      -# display progress bar
      - adjusted_score = [full_score - sum_cost, score].min
      - pct_adj = (adjusted_score / full_score.to_f) * 100
      - extra_points = [0, score - adjusted_score].max
      - pct_extra = (extra_points / full_score.to_f) * 100
      - deduction_rem = [0, sum_cost - extra_points].max
      - pct_deduct_rem = (deduction_rem / full_score.to_f) * 100
      
      .progress.rounded-pill.bg-secondary-subtle{style: 'height: 0.7rem;'}
        - if pct_adj > 0
          .progress-bar{style: "width: #{pct_adj}%", class: cc}
        - if pct_extra > 0
          .progress-bar.bg-danger{style: "width: #{pct_extra}%"}
        -# spacer
        .progress-bar.bg-transparent{style: "width: #{[0, 100 - pct_adj - pct_extra - pct_deduct_rem].max}%"}
        - if pct_deduct_rem > 0
          .progress-bar.bg-danger{style: "width: #{pct_deduct_rem}%"}
      .d-flex.justify-content-between.align-items-center.mt-1
        %span.fw-bold{style: 'font-size: 0.85rem;'}
          = number_with_precision score, precision: 2, strip_insignificant_zeros: true
        %small.text-secondary.d-lg-none
          = text.join(', ')

  -# last submission column
  %td.d-none.d-lg-table-cell{style: 'min-width: 12rem; width: 12rem;'}
    = render partial: 'submission_short',
      locals: {submission: @prob_submissions[problem.id][:submission], problem_name: problem.name, problem_id: problem.id, sub_count: @prob_submissions[problem.id][:count], show_button: false, show_id: true }
  -# Action column
  %td{style: 'width: 4rem;'}
    .d-flex.flex-column.gap-1
      - if limit_reached
        %span.badge.badge-limit-danger.d-inline-flex.align-items-center.gap-1
          %span.mi{style: 'font-size: 0.8rem;'} block
          Limit
      - elsif problem.viva_exam?
        - if @prob_submissions[problem.id][:submission]
          = link_to 'Viva', viva_submission_path(@prob_submissions[problem.id][:submission]), class: 'btn btn-outline-primary btn-xs'
        - else
          = button_to 'Start', viva_start_problem_path(problem), class: 'btn btn-outline-success btn-xs', form: {style: 'display:inline-block'}
      - else
        - if @prob_submissions[problem.id][:submission]
          = link_to 'Edit', edit_submission_path(@prob_submissions[problem.id][:submission]), class: 'btn btn-outline-primary btn-xs'
        - else
          = link_to 'New', direct_edit_problem_submissions_path(problem.id), class: 'btn btn-outline-success btn-xs'
      -# on mobile, show a small link to results
      .d-lg-none
         - if @prob_submissions[problem.id][:submission]
           = link_to evaluations_submission_path(@prob_submissions[problem.id][:submission]), class: 'text-info', data: {turbo: true, turbo_method: :post} do
             %span.mi{style: 'font-size: 1.2rem;'} info
  -# hidden column
  %td
    = problem.public_tags.pluck(:name).join ','
