.card.card-shadow.mb-4{data: {controller: 'form--filter-problem'}}
  .card-header.bg-light.fw-bold
    %i.mi.mi-filter-list.me-2
    Filter Problems
  .card-body
    .row.mb-3
      .col-12
        .form-check.form-check-inline
          = radio_button_tag :'probs[use]', :all, params.dig(:probs, :use) != 'ids', class: 'form-check-input', id: 'probs_use_all', data: { action: 'change->form--filter-problem#filterChanged', 'form--filter-problem-target': 'useOption' }
          = label_tag :probs_use_all, "All Problems", class: 'form-check-label fw-bold'
        .form-check.form-check-inline
          = radio_button_tag :'probs[use]', :ids, params.dig(:probs, :use) == 'ids', class: 'form-check-input', id: 'probs_use_ids', data: { action: 'change->form--filter-problem#filterChanged', 'form--filter-problem-target': 'useOption' }
          = label_tag :probs_use_ids, "Specific Problems", class: 'form-check-label fw-bold'
    
    .row.g-3#problem-selection-container{data: { 'form--filter-problem-target': 'idSelect' }}
      .col-12
        .d-flex.gap-2.mb-2
          %button.btn.btn-sm.btn-outline-secondary{type: 'button', data: { action: 'click->form--filter-problem#clearAll' }} 
            %i.mi.mi-backspace.me-1
            Clear All
        
        = select_tag 'probs[ids][]',
            options_for_select(@problems_all.collect {|p| ["[#{p.name}] #{p.full_name}", p.id]}, params.dig(:probs, :ids)),
            { class: 'select2 form-control', multiple: "true", data: { 'form--filter-problem-target': 'idSelectInput' } }
